      "type": "command",
      "text": "glxinfo 2>/dev/null | grep 'OpenGL version' | sed 's/.*NVIDIA / /' | sed 's/$/ /' | awk '{print $1, $2, $3}'",
      "key": "  пҖ© GPU Driver",
      "keyColor": "magenta"
    },
    {
      "type": "memory",
      "key": "  п’ј Memory ",
